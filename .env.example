# =============================================================================
# IDP Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Required variables are marked with [REQUIRED].
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# --- Database [REQUIRED] ---
DATABASE_URL=postgresql://idp:idp_secret@localhost:5432/idp_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Authentication [REQUIRED] ---
JWT_SECRET=dev-secret-change-in-production
JWT_ISSUER=idp-platform
JWT_AUDIENCE=idp-api
TOKEN_EXPIRATION_SECONDS=3600

# --- OIDC (Optional - for SSO) ---
OIDC_ISSUER_URL=https://dev-123456.okta.com/oauth2/default
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Rate Limiting ---
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# --- AWS (LocalStack in dev) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566

# --- S3 ---
S3_BUCKET_ARTIFACTS=idp-artifacts-dev
S3_BUCKET_BACKUPS=idp-backups-dev

# --- Notifications ---
SLACK_WEBHOOK_URL=
SMTP_HOST=localhost
SMTP_PORT=1025
PAGERDUTY_ROUTING_KEY=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=idp-api
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PORT=9090

# --- Feature Flags ---
FEATURE_SELF_SERVICE_INFRA=true
FEATURE_CANARY_DEPLOYMENTS=true
FEATURE_AUDIT_HASH_CHAIN=true

# --- Encryption ---
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_your_github_token

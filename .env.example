# =============================================================================
# IDP Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://idp:idp_secret@localhost:5432/idp_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=24h
OIDC_ISSUER_URL=https://dev-123456.okta.com/oauth2/default
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# AWS (LocalStack for development)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566

# S3
S3_BUCKET_ARTIFACTS=idp-artifacts-dev
S3_BUCKET_BACKUPS=idp-backups-dev

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=idp-api
PROMETHEUS_METRICS_PORT=9090

# External Services
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_ROUTING_KEY=your-routing-key
GITHUB_TOKEN=ghp_your_github_token

# Feature Flags
FEATURE_SELF_SERVICE_INFRA=true
FEATURE_CANARY_DEPLOYMENTS=true
FEATURE_AUDIT_HASH_CHAIN=true

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Encryption
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!

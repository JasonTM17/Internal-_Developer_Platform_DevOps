{
  "description": "Node-level metrics - CPU, memory, disk, and network per host",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "CPU", "type": "row" },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "percent", "max": 100 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        { "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}" }
      ],
      "title": "CPU Usage per Node",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\"}[5m])) * 100", "legendFormat": "user" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100", "legendFormat": "system" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100", "legendFormat": "iowait" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"steal\"}[5m])) * 100", "legendFormat": "steal" }
      ],
      "title": "CPU Mode Breakdown (Cluster Average)",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "title": "Memory", "type": "row" },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used - {{instance}}" },
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total - {{instance}}" }
      ],
      "title": "Memory Usage per Node",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        { "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "{{instance}}" }
      ],
      "title": "Memory Utilization %",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "id": 102, "title": "Disk", "type": "row" },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        { "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)", "legendFormat": "{{instance}}" }
      ],
      "title": "Root Disk Usage %",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 6,
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "Read {{instance}} {{device}}" },
        { "expr": "-rate(node_disk_written_bytes_total[5m])", "legendFormat": "Write {{instance}} {{device}}" }
      ],
      "title": "Disk I/O Throughput",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 103, "title": "Network", "type": "row" },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 7,
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br.*\"}[5m]) * 8", "legendFormat": "RX {{instance}} {{device}}" },
        { "expr": "-rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br.*\"}[5m]) * 8", "legendFormat": "TX {{instance}} {{device}}" }
      ],
      "title": "Network Bandwidth",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 8,
      "targets": [
        { "expr": "rate(node_network_receive_errs_total[5m])", "legendFormat": "RX Errors {{instance}}" },
        { "expr": "rate(node_network_transmit_errs_total[5m])", "legendFormat": "TX Errors {{instance}}" },
        { "expr": "rate(node_network_receive_drop_total[5m])", "legendFormat": "RX Drops {{instance}}" }
      ],
      "title": "Network Errors & Drops",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["node-exporter", "infrastructure", "hardware"],
  "templating": {
    "list": [
      { "name": "datasource", "query": "prometheus", "type": "datasource" },
      { "datasource": "Prometheus", "name": "instance", "query": "label_values(node_uname_info, instance)", "type": "query", "includeAll": true, "multi": true }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Node Exporter Metrics",
  "uid": "node-exporter-metrics",
  "version": 1
}

{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "IDP Platform Cost Analysis - Namespace, service, and resource cost breakdown",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Monthly Cost (Estimated)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(kubecost_cluster_monthly_cost)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost Efficiency Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "avg(kubecost_savings_cpu_allocation_average / kubecost_savings_cpu_request_average) * 100",
          "legendFormat": "Efficiency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "title": "Spot vs On-Demand Savings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(kubecost_node_is_spot * kubecost_node_monthly_cost) / sum(kubecost_node_monthly_cost) * 100",
          "legendFormat": "Spot %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "title": "Monthly Savings Potential",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(kubecost_savings_monthly_savings_total)",
          "legendFormat": "Potential Savings"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "title": "Cost by Namespace (Daily)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (namespace) (kubecost_namespace_daily_cost)",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Cost by Service",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (label_app) (kubecost_pod_monthly_cost{namespace=\"idp-platform\"})",
          "legendFormat": "{{ label_app }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "title": "CPU Request vs Actual Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\", namespace=\"idp-platform\"})",
          "legendFormat": "CPU Requested"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"idp-platform\", container!=\"\"}[5m]))",
          "legendFormat": "CPU Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Memory Request vs Actual Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_requests{resource=\"memory\", namespace=\"idp-platform\"})",
          "legendFormat": "Memory Requested"
        },
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"idp-platform\", container!=\"\"})",
          "legendFormat": "Memory Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Node Cost Breakdown",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "kubecost_node_monthly_cost",
          "legendFormat": "{{ node }}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "node": "Node",
              "Value": "Monthly Cost ($)"
            }
          }
        }
      ]
    },
    {
      "title": "Idle Resources (Waste)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum by (namespace) ((kube_pod_container_resource_requests{resource=\"cpu\"} - rate(container_cpu_usage_seconds_total[5m])) * 0.031611 * 730)",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost Trend (30 Days)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(kubecost_cluster_daily_cost)",
          "legendFormat": "Daily Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["cost", "kubecost", "idp-platform", "finops"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(kubecost_namespace_daily_cost, namespace)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "timeRange",
        "type": "interval",
        "query": "1h,6h,12h,1d,7d,30d",
        "current": { "value": "7d" }
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "IDP Platform - Cost Analysis",
  "uid": "idp-cost-analysis",
  "version": 1
}

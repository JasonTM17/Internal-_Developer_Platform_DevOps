{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Performance Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"idp-api\"}[5m])) by (path)", "legendFormat": "{{path}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "title": "Latency by Endpoint (P95)",
      "type": "timeseries",
      "targets": [
        { "expr": "idp:api:latency_p95_by_endpoint:5m", "legendFormat": "{{path}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Error Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"idp-api\",status=~\"5..\"}[5m])) by (path) / sum(rate(http_requests_total{job=\"idp-api\"}[5m])) by (path)", "legendFormat": "{{path}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "targets": [
        { "expr": "sum(increase(http_requests_total{job=\"idp-api\"}[1h])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Resource Utilization",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 8,
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "idp:pod:cpu_utilization:5m{namespace=\"idp-production\"}", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 9,
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "container_memory_working_set_bytes{namespace=\"idp-production\",container=\"idp-api\"}", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 10,
      "title": "Active Database Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"idp_production\"}", "legendFormat": "Active" },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max" }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["idp", "api", "performance"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "IDP API Performance",
  "uid": "idp-api-performance",
  "version": 1
}

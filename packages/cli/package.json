{
  "name": "@idp/cli",
  "version": "0.1.0",
  "description": "Developer CLI for the Internal Developer Platform",
  "bin": {
    "idp": "./dist/bin/idp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'CLI tests pending'",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "idp",
    "developer-platform",
    "cli",
    "devops"
  ],
  "files": [

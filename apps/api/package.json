{
  "name": "@idp/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API server (Node.js/TypeScript/Express)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "echo 'api dev server'",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@idp/config": "workspace:*",
    "@idp/shared": "workspace:*",
    "express": "^4.18.0",
    "jose": "^5.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

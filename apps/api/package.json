{
  "name": "@idp/api",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Backend API server (Node.js/TypeScript/Express)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@idp/config": "workspace:*",
    "@idp/shared": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jose": "^5.2.0",
    "pg": "^8.11.0",
    "prom-client": "^15.1.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "bullmq": "^5.76.8",
    "fast-check": "^3.15.0",
    "nats": "^2.29.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

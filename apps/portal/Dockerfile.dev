FROM node:20-alpine
WORKDIR /app

RUN apk add --no-cache curl

# Install dependencies directly (standalone, not via pnpm workspace)
COPY package.json ./
RUN sed -i '/@idp\/shared/d' package.json && sed -i 's/"workspace:\*"/"*"/g' package.json && npm install --legacy-peer-deps

# Copy source
COPY index.html ./
COPY vite.config.ts ./
COPY tsconfig.json ./
COPY src/ ./src/

ENV NODE_ENV=development
ENV VITE_API_URL=http://localhost:3000

EXPOSE 5173

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:5173 || exit 1

CMD ["npx", "vite", "--host", "0.0.0.0"]
